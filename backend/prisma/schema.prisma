generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum TenantMembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  LEFT
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model Tenant {
  id          String             @id @default(uuid()) @db.Uuid
  name        String             @db.VarChar(200)
  slug        String             @unique @db.VarChar(100)
  status      TenantStatus       @default(ACTIVE)
  createdAt   DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @db.Timestamptz(6)
  memberships TenantMembership[]
  roles       Role[]

  @@map("tenants")
}

model User {
  id               String             @id @default(uuid()) @db.Uuid
  email            String             @unique @db.VarChar(320)
  passwordHash     String             @db.VarChar(255)
  firstName        String             @db.VarChar(100)
  lastName         String             @db.VarChar(100)
  displayName      String             @db.VarChar(200)
  phone            String?            @db.VarChar(50)
  status           UserStatus         @default(INVITED)
  emailVerifiedAt  DateTime?          @db.Timestamptz(6)
  lastLoginAt      DateTime?          @db.Timestamptz(6)
  createdAt        DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(6)
  memberships      TenantMembership[]
  sessions         UserSession[]

  @@map("users")
}

model TenantMembership {
  id          String                 @id @default(uuid()) @db.Uuid
  tenantId    String                 @db.Uuid
  userId      String                 @db.Uuid
  status      TenantMembershipStatus @default(INVITED)
  invitedAt   DateTime               @default(now()) @db.Timestamptz(6)
  joinedAt    DateTime?              @db.Timestamptz(6)
  createdAt   DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @db.Timestamptz(6)
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user        User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  roles       MembershipRole[]
  sessions    UserSession[]

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@index([userId, status])
  @@map("tenant_memberships")
}

model Role {
  id               String           @id @default(uuid()) @db.Uuid
  tenantId         String           @db.Uuid
  key              String           @db.VarChar(100)
  displayName      String           @db.VarChar(150)
  description      String?          @db.VarChar(500)
  isSystemTemplate Boolean          @default(false)
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  permissions      RolePermission[]
  memberships      MembershipRole[]

  @@unique([tenantId, key])
  @@index([tenantId, isSystemTemplate])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(150)
  displayName String           @db.VarChar(150)
  description String?          @db.VarChar(500)
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(6)
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model MembershipRole {
  id            String           @id @default(uuid()) @db.Uuid
  membershipId  String           @db.Uuid
  roleId        String           @db.Uuid
  assignedAt    DateTime         @default(now()) @db.Timestamptz(6)
  membership    TenantMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role          Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([membershipId, roleId])
  @@index([roleId])
  @@map("membership_roles")
}

model UserSession {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @db.Uuid
  tenantMembershipId String           @db.Uuid
  sessionTokenHash   String           @unique @db.VarChar(255)
  refreshTokenHash   String?          @unique @db.VarChar(255)
  ipAddress          String?          @db.VarChar(64)
  userAgent          String?          @db.VarChar(500)
  status             SessionStatus    @default(ACTIVE)
  expiresAt          DateTime         @db.Timestamptz(6)
  lastSeenAt         DateTime?        @db.Timestamptz(6)
  revokedAt          DateTime?        @db.Timestamptz(6)
  createdAt          DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @db.Timestamptz(6)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([tenantMembershipId, status])
  @@index([expiresAt])
  @@map("user_sessions")
}
