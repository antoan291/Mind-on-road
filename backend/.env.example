NODE_ENV=development
PORT=3001
WEB_APP_URL=http://localhost:5173
SESSION_TTL_HOURS=12
AUTH_COOKIE_NAME=mindonroad_session
BOOTSTRAP_TENANT_NAME=MindOnRoad Demo School
BOOTSTRAP_TENANT_SLUG=mindonroad-demo-school
BOOTSTRAP_OWNER_FIRST_NAME=System
BOOTSTRAP_OWNER_LAST_NAME=Owner
BOOTSTRAP_OWNER_EMAIL=owner@mindonroad.local
BOOTSTRAP_OWNER_PHONE=+359700000001
# Optional local-dev only. If omitted, a temporary owner password is generated on first bootstrap.
BOOTSTRAP_OWNER_PASSWORD=
POSTGRES_DB=mindonroad
POSTGRES_USER=mindonroad
# IMPORTANT: Use a strong, unique password in staging/production
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://mindonroad:change-me-in-production@localhost:5433/mindonroad
DIRECT_DATABASE_URL=postgresql://mindonroad:change-me-in-production@localhost:5433/mindonroad
REDIS_URL=redis://localhost:6379
# IMPORTANT: Must be at least 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-must-be-at-least-32-characters-long
OBJECT_STORAGE_BUCKET=mindonroad-documents
OBJECT_STORAGE_REGION=eu-central
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# IMPORTANT: Use strong, unique credentials in staging/production
OBJECT_STORAGE_ACCESS_KEY=change-me-access-key
OBJECT_STORAGE_SECRET_KEY=change-me-secret-key
OPENAI_API_KEY=
